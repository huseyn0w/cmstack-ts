// Cmstack-TS database schema.
//
// PostgreSQL is the default. Access goes exclusively through Prisma and the
// schema is kept DB-agnostic so MySQL works for shared hosting.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Accounts (Phase 1) ------------------------------------------------------

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  name                String?
  /// Argon2id hash. Null for users who only sign in via an OAuth provider.
  passwordHash        String?
  image               String?
  /// Public author bio, shown on the author profile page.
  bio                 String?
  emailVerified       DateTime?
  roleId              String?
  role                Role?                @relation(fields: [roleId], references: [id], onDelete: SetNull)
  accounts            Account[]
  posts               Post[]
  pages               Page[]
  revisions           Revision[]
  media               Media[]
  comments            Comment[]
  likes               PostLike[]
  passwordResetTokens PasswordResetToken[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([roleId])
}

/// A single-use, hashed password-reset token with an expiry. Only the SHA-256
/// hash of the token is stored; the raw token lives only in the emailed link.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

/// Links a user to an external OAuth identity (Google, GitHub, ...).
model Account {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String
  providerAccountId String
  createdAt         DateTime @default(now())

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  permissions Permission[]
  users       User[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

/// A granular (action, subject) permission, mapped 1:1 to a CASL rule.
model Permission {
  id      String @id @default(cuid())
  action  String
  subject String
  roles   Role[]

  @@unique([action, subject])
}

// --- Content (Phase 2) -------------------------------------------------------

enum ContentStatus {
  DRAFT
  PUBLISHED
}

model Post {
  id              String            @id @default(cuid())
  title           String
  slug            String            @unique
  excerpt         String?
  /// Sanitized HTML produced by the editor.
  content         String
  status          ContentStatus     @default(DRAFT)
  publishedAt     DateTime?
  /// Default-locale (en) SEO meta; per-locale overrides live in PostTranslation.
  metaTitle       String?
  metaDescription String?
  /// Structural SEO (NOT per-locale): custom canonical URL + search-index opt-out.
  canonicalUrl    String?
  noindex         Boolean           @default(false)
  authorId        String?
  author          User?             @relation(fields: [authorId], references: [id], onDelete: SetNull)
  categories      Category[]        @relation("PostCategories")
  tags            Tag[]             @relation("PostTags")
  revisions       Revision[]
  comments        Comment[]
  likes           PostLike[]
  translations    PostTranslation[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  /// Soft delete: non-null means trashed.
  deletedAt       DateTime?

  @@index([status, publishedAt])
  @@index([authorId])
}

/// Per-locale translation of a Post. The base Post row holds the default locale
/// (en); only non-default locales (de/ru) get a row here. Every translatable
/// field is nullable so a missing field falls back to the base at read time.
model PostTranslation {
  id              String   @id @default(cuid())
  postId          String
  post            Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  locale          String
  title           String?
  excerpt         String?
  /// Sanitized HTML when present.
  content         String?
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([postId, locale])
  @@index([locale])
}

/// A like on a post by a signed-in user (one per user per post).
model PostLike {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
}

model Page {
  id              String            @id @default(cuid())
  title           String
  slug            String            @unique
  content         String
  status          ContentStatus     @default(DRAFT)
  /// Default-locale (en) SEO meta; per-locale overrides live in PageTranslation.
  metaTitle       String?
  metaDescription String?
  /// Structural SEO (NOT per-locale): custom canonical URL + search-index opt-out.
  canonicalUrl    String?
  noindex         Boolean           @default(false)
  authorId        String?
  author          User?             @relation(fields: [authorId], references: [id], onDelete: SetNull)
  revisions       Revision[]
  translations    PageTranslation[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?

  @@index([status])
}

/// Per-locale translation of a Page (see PostTranslation). Pages have no excerpt.
model PageTranslation {
  id              String   @id @default(cuid())
  pageId          String
  page            Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  locale          String
  title           String?
  /// Sanitized HTML when present.
  content         String?
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([pageId, locale])
  @@index([locale])
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryTree")
  posts       Post[]     @relation("PostCategories")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([parentId])
}

model Tag {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  posts     Post[]   @relation("PostTags")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// An immutable snapshot of a Post or Page captured before each update, enabling
///  revision history. Exactly one of postId/pageId is set.
model Revision {
  id        String   @id @default(cuid())
  postId    String?
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  pageId    String?
  page      Page?    @relation(fields: [pageId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  /// The content fields as they were at this version (title, content, ...).
  snapshot  Json
  createdAt DateTime @default(now())

  @@index([postId])
  @@index([pageId])
}

// --- Media (Phase 3) ---------------------------------------------------------

model Media {
  id           String   @id @default(cuid())
  /// Stored filename / storage key (unique, generated; never the raw upload name).
  filename     String   @unique
  originalName String
  mimeType     String
  size         Int
  width        Int?
  height       Int?
  alt          String?
  title        String?
  caption      String?
  /// Path the file is served at, relative to the API origin (e.g. /uploads/<key>).
  url          String
  uploaderId   String?
  uploader     User?    @relation(fields: [uploaderId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([uploaderId])
  @@index([createdAt])
}

// --- Settings (Phase 5) ------------------------------------------------------

/// Key/value site settings owned by the API (the source of truth). Phase 5 uses
/// the `activeTheme` key to select which public theme the web app renders through.
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// --- SEO / GEO (Phase 7) -----------------------------------------------------

/// Singleton site/organization profile (one row, id "default"). Drives SEO
/// metadata, Organization JSON-LD, and the GEO statement surfaced to AI crawlers.
model SiteProfile {
  id               String   @id @default("default")
  organizationName String   @default("Cmstack-TS")
  tagline          String   @default("")
  description      String   @default("")
  url              String   @default("")
  logoUrl          String   @default("")
  /// Freeform "what we want AI assistants to recommend us for" copy.
  geoStatement     String   @default("")
  updatedAt        DateTime @updatedAt
}

/// An offered service. Surfaced as Service JSON-LD + in llms.txt + /services.
model Service {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
}

/// A frequently-asked question. Surfaced as FAQPage JSON-LD + in llms.txt.
model FaqItem {
  id        String   @id @default(cuid())
  question  String
  answer    String   @default("")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}

// --- Menus / Navigation (Task 1 §7 #4) ---------------------------------------

enum MenuItemType {
  POST
  PAGE
  CATEGORY
  CUSTOM
}

/// A named navigation menu bound to a theme render location (e.g. "primary",
/// "footer"). The location is the stable key the public theme renders by.
model Menu {
  id        String     @id @default(cuid())
  name      String
  location  String     @unique
  items     MenuItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

/// A single menu entry. Nested via self-referential parentId (public dropdowns).
/// targetId is a polymorphic, non-FK reference to a Post/Page/Category row for
/// the matching type; CUSTOM items carry a url instead. The base label is the
/// default locale (en); per-locale overrides live in MenuItemTranslation.
model MenuItem {
  id           String                @id @default(cuid())
  menuId       String
  menu         Menu                  @relation(fields: [menuId], references: [id], onDelete: Cascade)
  parentId     String?
  parent       MenuItem?             @relation("MenuItemTree", fields: [parentId], references: [id], onDelete: Cascade)
  children     MenuItem[]            @relation("MenuItemTree")
  order        Int                   @default(0)
  type         MenuItemType
  label        String
  targetId     String?
  url          String?
  openInNewTab Boolean               @default(false)
  translations MenuItemTranslation[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@index([menuId])
  @@index([parentId])
}

/// Per-locale label override for a MenuItem (see PostTranslation pattern). Only
/// the label is translatable; a null label falls back to the base item label.
model MenuItemTranslation {
  id         String   @id @default(cuid())
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  locale     String
  label      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([menuItemId, locale])
  @@index([locale])
}

// --- Comments (Phase 8) ------------------------------------------------------

enum CommentStatus {
  PENDING
  APPROVED
  SPAM
  TRASH
}

/// A threaded comment on a post. Guests comment with name+email; signed-in users
/// are linked via userId. New comments start PENDING and need moderation.
model Comment {
  id          String        @id @default(cuid())
  postId      String
  post        Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  /// Self-reference for threading. Replies are removed with their parent.
  parentId    String?
  parent      Comment?      @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies     Comment[]     @relation("CommentThread")
  /// Display name + email snapshot (from the user for signed-in authors).
  authorName  String
  authorEmail String
  /// Set when an authenticated user authored the comment.
  userId      String?
  user        User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  /// Plain text (rendered escaped).
  content     String
  status      CommentStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([postId, status])
  @@index([parentId])
  @@index([status])
}
