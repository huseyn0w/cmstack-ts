// Typress database schema.
//
// PostgreSQL is the default. Access goes exclusively through Prisma and the
// schema is kept DB-agnostic so MySQL works for shared hosting.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Accounts (Phase 1) ------------------------------------------------------

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  /// Argon2id hash. Null for users who only sign in via an OAuth provider.
  passwordHash String?
  image        String?
  emailVerified DateTime?
  roleId       String?
  role         Role?     @relation(fields: [roleId], references: [id], onDelete: SetNull)
  accounts     Account[]
  posts        Post[]
  pages        Page[]
  revisions    Revision[]
  media        Media[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([roleId])
}

/// Links a user to an external OAuth identity (Google, GitHub, ...).
model Account {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String
  providerAccountId String
  createdAt         DateTime @default(now())

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  permissions Permission[]
  users       User[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

/// A granular (action, subject) permission, mapped 1:1 to a CASL rule.
model Permission {
  id      String @id @default(cuid())
  action  String
  subject String
  roles   Role[]

  @@unique([action, subject])
}

// --- Content (Phase 2) -------------------------------------------------------

enum ContentStatus {
  DRAFT
  PUBLISHED
}

model Post {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  excerpt     String?
  /// Sanitized HTML produced by the editor.
  content     String
  status      ContentStatus @default(DRAFT)
  publishedAt DateTime?
  authorId    String?
  author      User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)
  categories  Category[]    @relation("PostCategories")
  tags        Tag[]         @relation("PostTags")
  revisions   Revision[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  /// Soft delete: non-null means trashed.
  deletedAt   DateTime?

  @@index([status, publishedAt])
  @@index([authorId])
}

model Page {
  id        String        @id @default(cuid())
  title     String
  slug      String        @unique
  content   String
  status    ContentStatus @default(DRAFT)
  authorId  String?
  author    User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)
  revisions Revision[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?

  @@index([status])
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryTree")
  posts       Post[]     @relation("PostCategories")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([parentId])
}

model Tag {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  posts     Post[]   @relation("PostTags")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// An immutable snapshot of a Post or Page captured before each update, enabling
/// WordPress-style revision history. Exactly one of postId/pageId is set.
model Revision {
  id        String   @id @default(cuid())
  postId    String?
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  pageId    String?
  page      Page?    @relation(fields: [pageId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  /// The content fields as they were at this version (title, content, ...).
  snapshot  Json
  createdAt DateTime @default(now())

  @@index([postId])
  @@index([pageId])
}

// --- Media (Phase 3) ---------------------------------------------------------

model Media {
  id           String   @id @default(cuid())
  /// Stored filename / storage key (unique, generated; never the raw upload name).
  filename     String   @unique
  originalName String
  mimeType     String
  size         Int
  width        Int?
  height       Int?
  alt          String?
  title        String?
  caption      String?
  /// Path the file is served at, relative to the API origin (e.g. /uploads/<key>).
  url          String
  uploaderId   String?
  uploader     User?    @relation(fields: [uploaderId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([uploaderId])
  @@index([createdAt])
}

// --- Settings (Phase 5) ------------------------------------------------------

/// Key/value site settings owned by the API (the source of truth). Phase 5 uses
/// the `activeTheme` key to select which public theme the web app renders through.
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
