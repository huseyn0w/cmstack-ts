# ---------------------------------------------------------------------------
# Typress environment. Copy to `.env` and fill in. NEVER commit a real .env.
# All variables are validated at boot by packages/config (Zod). See its schema.
# ---------------------------------------------------------------------------

# Runtime
NODE_ENV=development

# Database (PostgreSQL by default; kept DB-agnostic via Prisma)
# When using docker compose, host is `db`; locally it is `localhost`.
POSTGRES_USER=typress
POSTGRES_PASSWORD=typress
POSTGRES_DB=typress
DATABASE_URL=postgresql://typress:typress@localhost:5432/typress?schema=public

# API (NestJS)
API_PORT=4000

# Web (Next.js)
# Public base URL the browser uses to reach the API.
NEXT_PUBLIC_API_URL=http://localhost:4000
# Server-side (SSR / container-to-container) API URL; defaults to NEXT_PUBLIC_API_URL.
# In docker compose this is set to http://api:4000.
API_INTERNAL_URL=http://localhost:4000

# --- The following are placeholders for later phases; safe to leave as-is now ---

# Auth.js / NextAuth (Phase 1). Generate with: openssl rand -base64 32
AUTH_SECRET=change-me-in-production

# Social login providers (Phase 1) — leave blank to disable a provider.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Spam protection (Phase 8) — reCAPTCHA v3
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
