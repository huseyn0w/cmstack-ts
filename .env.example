# ---------------------------------------------------------------------------
# Cmstack-TS environment. Copy to `.env` and fill in. NEVER commit a real .env.
# All variables are validated at boot by packages/config (Zod). See its schema.
# ---------------------------------------------------------------------------

# Runtime
NODE_ENV=development

# Database (PostgreSQL by default; kept DB-agnostic via Prisma)
# When using docker compose, host is `db`; locally it is `localhost`.
POSTGRES_USER=cmstack-ts
POSTGRES_PASSWORD=cmstack-ts
POSTGRES_DB=cmstack-ts
DATABASE_URL=postgresql://cmstack-ts:cmstack-ts@localhost:5432/cmstack-ts?schema=public

# API (NestJS)
API_PORT=4000

# Secret used to sign/verify API JWTs. Shared with the web app's Auth.js.
# Generate with: openssl rand -base64 32
AUTH_SECRET=dev-only-change-me-32+chars-please
# Access-token lifetime (any value `ms`/jsonwebtoken accepts, e.g. 7d, 12h, 3600).
AUTH_TOKEN_TTL=7d
# Shared secret guarding server-to-server endpoints (web → API OAuth upsert).
# Generate with: openssl rand -base64 32
INTERNAL_API_SECRET=dev-only-change-me-internal-secret

# Media uploads: directory on disk and max accepted file size (MB).
UPLOAD_DIR=uploads
MEDIA_MAX_SIZE_MB=10
# Reject images above this many megapixels before processing (decompression-bomb guard).
MEDIA_MAX_MEGAPIXELS=40

# Web (Next.js)
# Public base URL the browser uses to reach the API.
NEXT_PUBLIC_API_URL=http://localhost:4000
# Origin allowed to call the API from the browser (CORS). The web app's URL.
WEB_ORIGIN=http://localhost:3000
# Public URL the web app is served from (Auth.js).
AUTH_URL=http://localhost:3000
# Canonical public base URL for SEO (sitemap, robots, llms.txt, canonical URLs,
# JSON-LD). Defaults to AUTH_URL when unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Server-side (SSR / container-to-container) API URL; defaults to NEXT_PUBLIC_API_URL.
# In docker compose this is set to http://api:4000.
API_INTERNAL_URL=http://localhost:4000

# AI integration (Phase 10) — the MCP server (apps/mcp) authenticates to the API
# with a service account and exposes scoped, CASL-checked tools to AI clients.
# Its capabilities are bounded by this account's role (point it at an
# Administrator for full control, or a lower role to constrain it).
MCP_API_URL=http://localhost:4000
MCP_API_EMAIL=admin@cmstack-ts.local
MCP_API_PASSWORD=admin12345

# Social login providers (web / Auth.js) — leave blank to disable a provider.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# --- The following are placeholders for later phases; safe to leave as-is now ---

# Spam protection (Phase 8) — reCAPTCHA v3. Leave blank to disable (comment
# submission and auth still work; verification is simply skipped).
# Browser-exposed site key (used by the comment form):
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
# Server-side secret (used by the API to verify tokens):
RECAPTCHA_SECRET_KEY=
# Minimum acceptable v3 score (0..1) when reCAPTCHA is enabled.
RECAPTCHA_MIN_SCORE=0.5

# Transactional email (SMTP) — used for password-reset links. Leave SMTP_HOST
# blank to disable real delivery: the API then logs the email (and reset link)
# to its console, so local/demo password reset works without an SMTP server.
SMTP_HOST=
SMTP_PORT=587
# true for implicit TLS (port 465); false for STARTTLS (587).
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
# From address on outgoing mail.
MAIL_FROM=Cmstack-TS <noreply@localhost>
# How long a password-reset link stays valid (minutes).
PASSWORD_RESET_TTL_MINUTES=60

# Recipient for contact-form messages. Optional: the admin-editable
# SiteProfile.contactEmail takes precedence; if both are empty, MAIL_FROM is used.
CONTACT_RECIPIENT_EMAIL=

# Recipient for new-comment moderation notifications. Optional: SiteProfile.contactEmail
# takes precedence, then this, then CONTACT_RECIPIENT_EMAIL, then MAIL_FROM. The email
# links to WEB_ORIGIN/admin/comments when WEB_ORIGIN is set.
COMMENT_NOTIFICATION_EMAIL=

# Caching layer. Leave REDIS_URL blank to use an in-process memory cache
# (single worker only); set it to a redis:// URL for a shared, multi-worker
# cache. CACHE_TTL_SECONDS is the default TTL for cached public reads;
# CACHE_ENABLED=false disables caching entirely (every read hits the source).
REDIS_URL=
CACHE_TTL_SECONDS=300
CACHE_ENABLED=true
